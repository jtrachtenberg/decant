{
  "name": "decant",
  "version": "0.3.1",
  "private": true,
  "description": "Convert files to Markdown before they upload to LLM chat UIs.",
  "type": "module",
  "imports": {
    "#pdfjs": {
      "browser": "pdfjs-dist/build/pdf.mjs",
      "node": "pdfjs-dist/legacy/build/pdf.mjs",
      "default": "pdfjs-dist/build/pdf.mjs"
    }
  },
  "bin": {
    "decant": "src/cli/decant.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:firefox": "node build.mjs --firefox",
    "package": "node build.mjs && node scripts/package.mjs",
    "package:firefox": "node build.mjs --firefox && node scripts/package.mjs --firefox",
    "watch": "node build.mjs --watch",
    "watch:firefox": "node build.mjs --watch --firefox",
    "test": "node --test",
    "build:cli": "node scripts/build-cli.mjs",
    "mock-endpoint": "node scripts/mock-endpoint.mjs",
    "inspect": "node scripts/inspect-pdf.mjs"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@mixmark-io/domino": "^2.2.0",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "web-streams-polyfill": "^4.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}

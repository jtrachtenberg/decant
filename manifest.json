{
  "manifest_version": 3,
  "name": "Decant (dev)",
  "version": "0.0.1",
  "description": "Convert files to Markdown before they upload to LLM chat UIs. Milestone 1: in-browser PDF to Markdown on claude.ai.",
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/intercept.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.mjs"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}

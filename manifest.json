{
  "manifest_version": 3,
  "name": "Decant (dev)",
  "version": "0.0.1",
  "description": "Convert files to Markdown before they upload to LLM chat UIs. Default-deny activation; converts PDFs in-browser.",
  "permissions": ["scripting", "storage"],
  "host_permissions": ["*://claude.ai/*"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.mjs"],
      "matches": ["*://*/*"]
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Decant",
  "version": "0.0.1",
  "description": "Convert PDF, Word, Excel, PowerPoint & HTML to Markdown before uploading to LLM chats - cut token cost, all in-browser.",
  "permissions": ["scripting", "storage"],
  "host_permissions": ["*://claude.ai/*", "*://chatgpt.com/*", "*://gemini.google.com/*"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
  "16": "decant_icon16.png",
  "48": "decant_icon48.png",
  "128": "decant_icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.mjs"],
      "matches": ["*://*/*"],
      "use_dynamic_url": true
    }
  ]
}
